n    return(\r\n        <div className='about'>\r\n            <h1 className='gradient-text'>Добро пожаловать в URL-Shortener</h1>\r\n            <p>Сократитель ссылок — это простой инструмент, который преобразует длинные интернет-адреса в короткие. Работает это примерно как перевод с одного языка на другой, только языки эти — форматы записи веб-адресов. Представь себе обычную ссылку: длинную цепочку из букв, цифр, символов, которая занимает несколько строк. Это может быть адрес статьи, товара в интернет-магазине или видео. Сократитель берёт этот длинный адрес и заменяет его на краткий вариант, обычно состоящий из букв и цифр. Технически, он создаёт в своей базе данных соответствие между коротким кодом и полным адресом. Когда кто-то нажимает на короткую ссылку, система моментально находит в своей памяти оригинальный адрес и перенаправляет пользователя по нему.</p>\r\n            <button className='start-use'>Начать использование</button>\r\n        </div>\r\n    );\r\n}\r\n\r\nexport default Login;"],"mappings":";AAAA,OAAOA,KAAK,MAAM,OAAO;AAAC,SAAAC,MAAA,IAAAC,OAAA;AAE1B,SAASC,KAAKA,CAAA,EAAG;EACb,oBACID,OAAA;IAAKE,SAAS,EAAC,OAAO;IAAAC,QAAA,gBAClBH,OAAA;MAAIE,SAAS,EAAC,eAAe;MAAAC,QAAA,EAAC;IAAgC;MAAAC,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OAAI,CAAC,eACnEP,OAAA;MAAAG,QAAA,EAAG;IAAmtB;MAAAC,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OAAG,CAAC,eAC1tBP,OAAA;MAAQE,SAAS,EAAC,WAAW;MAAAC,QAAA,EAAC;IAAoB;MAAAC,QAAA,EAAAC,YAAA;MAAAC,UAAA;MAAAC,YAAA;IAAA,OAAQ,CAAC;EAAA;IAAAH,QAAA,EAAAC,YAAA;IAAAC,UAAA;IAAAC,YAAA;EAAA,OAC1D,CAAC;AAEd;AAACC,EAAA,GARQP,KAAK;AAUd,eAAeA,KAAK;AAAC,IAAAO,EAAA;AAAAC,YAAA,CAAAD,EAAA","ignoreList":[]},"metadata":{},"sourceType":"module","externalDependencies":[]}